{
    "extends": "astro/tsconfigs/strict",
    "compilerOptions": {
        "plugins": [
            {
                "name": "@astrojs/ts-plugin"
            },
        ],
        "types": [
            "bun-types"
        ],
        "jsx": "react-jsx",
        "jsxImportSource": "react",
        "allowImportingTsExtensions": true
    }
}
